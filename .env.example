# Copy the values you need into your shell before launching. There is no
# automatic .env loader — set these as real environment variables.
#
# PowerShell:   $env:GROQ_API_KEY = "gsk_your_key_here"
# bash/zsh:     export GROQ_API_KEY="gsk_your_key_here"

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
# Leave GROQ_API_KEY unset to run 100% locally on Ollama (the default).
# Set it to route LLM calls to Groq's hosted gpt-oss-120b instead.
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b

# Local Ollama model + host (used when GROQ_API_KEY is not set)
DEMO_MODEL=qwen2.5:3b
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Demo tuning
# ---------------------------------------------------------------------------
# DEMO_FAST=1 makes the planner skip its LLM call (deterministic plan) so a
# first run finishes in ~30-50s. Self-correction + executive insight stay real.
DEMO_FAST=1
# Max tokens per LLM completion.
DEMO_MAX_TOKENS=256

# Temporal gRPC endpoint (dev server default).
TEMPORAL_TARGET=localhost:7233
